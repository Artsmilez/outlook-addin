      <bt:Image id="Icon.16x16" DefaultValue="https://artsmilez.github.io/outlook-addin/assets/AIH-Logo1.png"/>
      <bt:Image id="Icon.32x32" DefaultValue="https://artsmilez.github.io/outlook-addin/assets/AIH-Logo1.png"/>
      <bt:Image id="Icon.80x80" DefaultValue="https://artsmilez.github.io/outlook-addin/assets/AIH-Logo1.png"/>
