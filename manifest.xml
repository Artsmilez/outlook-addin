  <Description DefaultValue="Meeting room amenities add-in"/>
  <IconUrl DefaultValue="https://artsmilez.github.io/outlook-addin/assets/AIH-Logo1.png"/>
  <HighResolutionIconUrl DefaultValue="https://artsmilez.github.io/outlook-addin/assets/AIH-Logo1.png"/>
  
