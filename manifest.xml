  </AppDomains>
  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>
  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.1"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://artsmilez.github.io/outlook-addin/taskpane.html?v=20260408g"/>
        <!-- Mobile -->
        <!-- <SourceLocation DefaultValue="https://abcd-1234.ngrok-free.app/taskpane.html"/> -->
        <RequestedHeight>250</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteItem</Permissions>
  
  <!-- REQUIRED for Mail add-ins: activation rules -->
  <Rule xsi:type="RuleCollection" Mode="Or">
    <!-- ให้แอดอินใช้งานได้ทั้งตอนเปิดอ่านนัด และตอนกำลังแก้ไข/สร้างนัด -->
    <Rule xsi:type="ItemIs" ItemType="Appointment" FormType="Read"/>
    <Rule xsi:type="ItemIs" ItemType="Appointment" FormType="Edit"/>
    <!-- Mobile 1 -->
    <!-- <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/> -->
  </Rule>
  
  <!-- <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Appointment" FormType="Edit"/>
  </Rule> -->

  <!-- <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
  </Rule> -->

  <DisableEntityHighlighting>false</DisableEntityHighlighting>
  
  
